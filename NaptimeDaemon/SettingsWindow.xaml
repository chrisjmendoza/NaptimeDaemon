<Window x:Class="NaptimeDaemon.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NaptimeDaemon Settings"
        Height="220"
        Width="300">

    <StackPanel Margin="20">

        <TextBlock Text="Sleep after (minutes)" FontWeight="Bold"/>

        <TextBox x:Name="IdleMinutesBox"
                 Margin="0,5,0,10"
                 Height="30"/>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="5 min"
                    Width="80"
                    Margin="0,0,10,0"
                    Click="Set5Min_Click"/>
            <Button Content="60 min"
                    Width="80"
                    Click="Set60Min_Click"/>
        </StackPanel>

        <Button Content="Save"
                Height="35"
                Click="Save_Click"/>

    </StackPanel>
</Window>
